# ── Ev.CRM Environment Variables ────────────────────────────────────
# Copy this file to .env.local and fill in your values

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Ev.CRM

# Google OAuth (for Drive + Gmail OTP)
# Get from: https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Google Apps Script OTP endpoint
# Deploy your Apps Script as a web app and paste the URL here
GOOGLE_APPS_SCRIPT_URL=

# WhatsApp Business API (via BSP like Interakt/Wati)
WHATSAPP_API_URL=
WHATSAPP_API_KEY=

# AWS (DynamoDB + other services)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
DYNAMODB_TABLE_PREFIX=evcrm_

# Razorpay (payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Google Gemini AI (lead classification)
GEMINI_API_KEY=

# JWT Secret (for session tokens)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Dealer default (for MVP demo mode)
NEXT_PUBLIC_DEMO_MODE=true
