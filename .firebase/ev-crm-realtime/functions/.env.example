# ══════════════════════════════════════════════════════════════════
#  Ev.CRM — Environment Variables
#  Copy: cp .env.example .env.local  then fill in values
# ══════════════════════════════════════════════════════════════════

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (get from supabase.com → Project → Settings → API)
# 1. Create a project, then run scripts/supabase-schema.sql once in the SQL Editor
# 2. NEXT_PUBLIC_SUPABASE_URL / ANON_KEY are for client-side Supabase Auth (lib/supabase.js)
# 3. SUPABASE_SERVICE_ROLE_KEY is the server-only key used for all CRM/marketplace
#    data (lib/store.js) — bypasses RLS, never expose it to the browser.
# Until these are set, the app transparently falls back to the local data/*.json
# files (same demo behavior as before) — nothing breaks by leaving this unset.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# JWT Secret (run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your-64-character-secret-here

# Email - Option A: Gmail (free 500/day)
GMAIL_USER=yourname@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Email - Option B: SendGrid (free 100/day)
# SENDGRID_API_KEY=SG.xxx

# Email - Option C: Resend (free 3000/month)
# RESEND_API_KEY=re_xxx

EMAIL_FROM_NAME=Ev.CRM
EMAIL_FROM_EMAIL=noreply@evcrm.in

# Razorpay — marketplace ₹1,000 test-drive token (held via manual capture, released/refunded from /dealer)
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxx
# Dashboard → Settings → Webhooks → add this URL + secret: https://<domain>/api/webhooks/razorpay
RAZORPAY_WEBHOOK_SECRET=xxx

# Razorpay — dealer SaaS billing (₹3,000/month after 30-day free trial)
# Create the plan once: Dashboard → Subscriptions → Plans → New Plan (₹3,000, monthly)
RAZORPAY_PLAN_ID=plan_xxx
# Register a SEPARATE webhook for this (different secret from the one above):
# Dashboard → Settings → Webhooks → https://<domain>/api/webhooks/razorpay-subscription
RAZORPAY_SUBSCRIPTION_WEBHOOK_SECRET=xxx

# Gemini AI
GEMINI_API_KEY=AIzaSy...
